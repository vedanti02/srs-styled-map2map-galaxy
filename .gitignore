# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
env/
.venv/
.env

# Jupyter / notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Training artifacts (large; reproducible from code + data)
checkpoints/
runs/
sbi-logs/
logs/
*.pt
*.pth
*.ckpt

# Inference outputs (regenerable; can be huge)
inference/output/
inference/transformed/
**/transformed/
**/transformed_*/

# Pk arrays and metrics (regenerable)
**/pk/
**/metrics_*.npz
**/posterior_*.pkl

# Plots (regenerable) — but keep the baseline plots referenced from SUMMARY.md
**/plots/
*.png
*.pdf
*.svg
!runs/
!runs/baseline/
!runs/baseline/plots/
!runs/baseline/plots/**

# Data caches/cubes under data/ (actual sim data lives on shared storage).
# We DO track Python loader modules in data/ — they're source code.
data/__pycache__/
data/**/*.npy
data/**/*.npz
data/**/*.h5

# SLURM
slurm-*.out
*.err
*.log

# Local scratch
scratch/
tmp/
*.tmp
